{
  "manifest_version": 3,
  "name": "Daily Timer",
  "version": "1.1",
  "description": "Temporizador de Daily conectado a la base de datos de Notion",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://api.notion.com/*", "https://www.notion.so/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.notion.so/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}