{
  "manifest_version": 3,
  "name": "Daily Timer",
  "version": "1.0",
  "description": "Temporizador de Daily conectado a la base de datos de Notion",
  "permissions": ["storage"],
  "host_permissions": ["https://api.notion.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}